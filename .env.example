NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# ANTHROPIC_API_KEY — set in Vercel dashboard (not in .env files)
# DISABLE_AI=1 — set to disable all AI features (for testing without credits)

# Public origin — used for metadataBase, robots, and sitemap.
NEXT_PUBLIC_APP_URL=https://haretoki.vercel.app

# PostHog — leave blank to disable analytics (provider becomes a no-op).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry (optional — leave blank to disable observability; SDK no-ops when unset)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=haretoki
SENTRY_PROJECT=haretoki-web

# Email (optional — partner invite delivery via Resend)
RESEND_API_KEY=
EMAIL_FROM=Haretoki <noreply@haretoki.app>

# Resend webhook secret (whsec_... format issued by Resend at webhook
# creation). Set the webhook endpoint to https://<host>/api/webhooks/resend
# in Resend dashboard, subscribe to email.{sent,delivered,delivery_delayed,
# bounced,complained,opened,clicked} events. Leave blank to disable
# delivery tracking (the webhook route returns 503 in that case).
RESEND_WEBHOOK_SECRET=

# Vercel BotID feature flag (production only). Set to "1" or "true" to
# enforce bot detection on /api/coach/stream + /api/user/{delete,export}.
# Leave unset in dev / preview so local testing isn't gated. The
# BotIdClient component in src/app/layout.tsx is always mounted; this
# flag just controls whether the server-side gate enforces.
BOT_ID_ENABLED=

# Cron secret — Bearer token for /api/cron/* routes. Vercel Cron sends this
# automatically when configured via vercel.json. Generate with `openssl rand -hex 32`.
CRON_SECRET=

# F1 venue-name-search (optional — Tier 2 silent-skips when the key is absent
# and the feature falls back to Claude-only suggestions).
# Google Places API key with the new `places.googleapis.com/v1` endpoint
# enabled. Used by `src/lib/venue-search/places.ts`.
GOOGLE_PLACES_API_KEY=
# Monthly soft cap per project for Places autocomplete sessions. Exceeding
# this disables Tier 2 and leaves Tier 3 (Claude) running. Default 3000.
PLACES_AUTOCOMPLETE_MONTHLY_CAP=3000
# Per-project per-minute rate limit for the venue-name-search server action.
# Defaults to 20 / minute when unset.
NAME_SEARCH_RATE_LIMIT_PER_MIN=20

# F4 — Guest invite cookie signing secrets (HMAC-SHA256).
# Two generations run in parallel so we can rotate without invalidating
# in-flight guest sessions. Rotation procedure:
#   1. Generate fresh value:      `openssl rand -hex 32`
#   2. Set GUEST_COOKIE_SECRET_K2 = old K1 (keeps existing cookies valid)
#   3. Set GUEST_COOKIE_SECRET_K1 = fresh value (signs new cookies)
#   4. After 24h, wipe K2 (existing cookies have all expired by then).
# Both secrets MUST be >= 16 chars in production. Both Vercel preview AND
# staging require explicit values; only `NODE_ENV === "test"` falls back to
# a known-fixture string (see src/lib/guest-session.ts).
GUEST_COOKIE_SECRET_K1=
GUEST_COOKIE_SECRET_K2=
