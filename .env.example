NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# ANTHROPIC_API_KEY — set in Vercel dashboard (not in .env files)
# DISABLE_AI=1 — set to disable all AI features (for testing without credits)

# Anthropic spend budgets (USD). The /api/cron/ai-cost-summary daily cron
# estimates AiCache + AiAnalysis + Estimate-row count over the past 24h /
# 30d, applies per-model pricing in src/lib/anthropic-usage.ts, and fires
# a Sentry warning (daily over) / error (monthly over) when the estimate
# trips the threshold. Defaults are conservative — bump in Vercel env.
ANTHROPIC_DAILY_BUDGET_USD=5
ANTHROPIC_MONTHLY_BUDGET_USD=100

# Upstash Redis (optional — when both URL + TOKEN are set, the rate
# limiter switches from per-instance in-memory to cluster-wide Redis.
# Provision via Vercel Marketplace → Upstash; the integration auto-
# injects both vars into prod env. Leave blank to keep in-memory.
# Operations doc: docs/ai/cost-baseline.md, ADR pending in next round.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin allow-list — comma-separated emails that can access /admin/*
# pages (/admin/cost, /admin/audit). Closed by default: when unset
# every /admin/* returns 404 (not 403, so the existence of admin
# surfaces isn't leaked). Case-insensitive match against the
# authenticated user's email.
ADMIN_EMAILS=

# CSP rollout knobs (round 16). Default: enforce strict CSP with
# per-request nonce + Vercel/Sentry/PostHog/Supabase allowlist.
#   CSP_DISABLED=1     — escape hatch, no CSP header at all
#   CSP_REPORT_ONLY=1  — emit Content-Security-Policy-Report-Only
#                        instead of Content-Security-Policy. Browser
#                        reports violations but doesn't block —
#                        recommended for the first 1-2 weeks of
#                        production observation.
CSP_DISABLED=
CSP_REPORT_ONLY=

# /.well-known/security.txt contact email override. Falls back to
# support@haretoki.app when unset. Set to a security-team alias
# once one exists (e.g. security@haretoki.app).
SECURITY_CONTACT_EMAIL=

# Daily AiCostSnapshot + AuditLog rolling cleanup horizon (days).
# Default 365 (12 months). Floor 90, ceiling 3650. Audit rows with
# action=user.delete.* are exempt from the sweep regardless.
DATA_RETENTION_DAYS=365

# Public origin — used for metadataBase, robots, and sitemap.
NEXT_PUBLIC_APP_URL=https://haretoki.vercel.app

# PostHog — leave blank to disable analytics (provider becomes a no-op).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ============================================================================
# Observability — Sentry + Vercel structured logs
# ============================================================================
# Alert taxonomy + event catalog: docs/harness/sentry-alerts.md
#
# All Sentry knobs no-op gracefully when DSN is unset (dev / CI / preview
# without a Sentry project provisioned). Production should set DSN +
# AUTH_TOKEN; Vercel Marketplace integration auto-injects DSN/ORG/PROJECT
# but AUTH_TOKEN is needed for source-map upload during build.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=haretoki
SENTRY_PROJECT=haretoki-web
# Performance trace sampling rate (0.0-1.0). 0.1 = 10% of requests get
# full performance trace. Bump per-release when investigating regressions.
# Leave at default (0.1, set in sentry.{client,server,edge}.config.ts) for
# steady state — too high a rate burns the Sentry quota fast.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email (optional — partner invite delivery via Resend)
RESEND_API_KEY=
EMAIL_FROM=Haretoki <noreply@haretoki.app>

# Resend webhook secret (whsec_... format issued by Resend at webhook
# creation). Set the webhook endpoint to https://<host>/api/webhooks/resend
# in Resend dashboard, subscribe to email.{sent,delivered,delivery_delayed,
# bounced,complained,opened,clicked} events. Leave blank to disable
# delivery tracking (the webhook route returns 503 in that case).
#
# Round 14: webhook now also routes bounce/complaint suppression
# notices to ADMIN_EMAILS via Resend, and persists per-user reason +
# timestamp on NotificationPreference so the daily
# /api/cron/email-suppression-retry cron can re-enable soft bounces
# after 7 days.
RESEND_WEBHOOK_SECRET=

# Vercel BotID feature flag (production only). Set to "1" or "true" to
# enforce bot detection on /api/coach/stream + /api/user/{delete,export}.
# Leave unset in dev / preview so local testing isn't gated. The
# BotIdClient component in src/app/layout.tsx is always mounted; this
# flag just controls whether the server-side gate enforces.
BOT_ID_ENABLED=

# Cron secret — Bearer token for /api/cron/* routes. Vercel Cron sends this
# automatically when configured via vercel.json. Generate with `openssl rand -hex 32`.
CRON_SECRET=

# F1 venue-name-search (optional — Tier 2 silent-skips when the key is absent
# and the feature falls back to Claude-only suggestions).
# Google Places API key with the new `places.googleapis.com/v1` endpoint
# enabled. Used by `src/lib/venue-search/places.ts`.
GOOGLE_PLACES_API_KEY=
# Monthly soft cap per project for Places autocomplete sessions. Exceeding
# this disables Tier 2 and leaves Tier 3 (Claude) running. Default 3000.
PLACES_AUTOCOMPLETE_MONTHLY_CAP=3000
# Per-project per-minute rate limit for the venue-name-search server action.
# Defaults to 20 / minute when unset.
NAME_SEARCH_RATE_LIMIT_PER_MIN=20

# F4 — Guest invite cookie signing secrets (HMAC-SHA256).
# Two generations run in parallel so we can rotate without invalidating
# in-flight guest sessions. Rotation procedure:
#   1. Generate fresh value:      `openssl rand -hex 32`
#   2. Set GUEST_COOKIE_SECRET_K2 = old K1 (keeps existing cookies valid)
#   3. Set GUEST_COOKIE_SECRET_K1 = fresh value (signs new cookies)
#   4. After 24h, wipe K2 (existing cookies have all expired by then).
# Both secrets MUST be >= 16 chars in production. Both Vercel preview AND
# staging require explicit values; only `NODE_ENV === "test"` falls back to
# a known-fixture string (see src/lib/guest-session.ts).
GUEST_COOKIE_SECRET_K1=
GUEST_COOKIE_SECRET_K2=

# /support contact form — destination address for couples' inquiries.
# Falls back to support@haretoki.app when unset; if Resend is not
# configured the form still records messages to the server log so the
# operator can recover them manually.
SUPPORT_EMAIL=support@haretoki.app
# Per-user rate limit on the contact form (messages / hour). Default 5.
SUPPORT_RATE_LIMIT_PER_HOUR=5

# ============================================================================
# Web Push (Track B-1) — visit reminders + post-visit memo nudges
# ============================================================================
# VAPID identity used by the Web Push protocol. The public key ships to the
# browser inside the PermissionSheet / PushPermissionState components and is
# bound to every PushSubscription record in the DB; the private key signs
# outgoing pushes from B-2's dispatcher cron. Keep them as a pair — rotating
# one without the other invalidates every subscription on file.
#
# Generate locally with:
#   npx web-push generate-vapid-keys --json
# Both values MUST be set in production for B-1's permission flow to render
# the opt-in CTA. Leaving them blank silently disables the post-visit sheet
# (the page still works, the suppression branch in PermissionSheet just
# never resolves "yes").
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Reply-To identity served alongside the push. Falls back to the SUPPORT
# contact when unset, but operators are expected to supply a stable mailto:
# so push providers (FCM/APNs) can route abuse complaints back to us.
VAPID_SUBJECT=mailto:support@haretoki.app
