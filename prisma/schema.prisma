/// P2.D Daily Anthropic cost snapshot — populated by
/// `/api/cron/ai-cost-summary` once per day. The admin /admin/cost page
/// reads the last 30 rows to render a dashboard without re-running the
/// cron's heavy aggregation. Stringly-typed `byBucket` (Json) so a new
/// model class doesn't require a migration.
model AiCostSnapshot {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// JST date (YYYY-MM-DD) the cron observed. UNIQUE so re-running the
  /// cron same day upserts the row instead of duplicating.
  snapshotDate      DateTime @unique @map("snapshot_date") @db.Date
  /// Daily window (24h) totals.
  dailyUsedUsd      Decimal  @map("daily_used_usd") @db.Decimal(10, 4)
  dailyBudgetUsd    Decimal  @map("daily_budget_usd") @db.Decimal(10, 4)
  /// Monthly window (30d) totals.
  monthlyUsedUsd    Decimal  @map("monthly_used_usd") @db.Decimal(10, 4)
  monthlyBudgetUsd  Decimal  @map("monthly_budget_usd") @db.Decimal(10, 4)
  /// Per-bucket detail (haiku / sonnet / sonnet-pdf) — same shape as the
  /// cron's daily.byBucket. `Json` so adding a new model class doesn't
  /// require a migration. App-level types in
  /// `src/lib/anthropic-cost-snapshot.ts`.
  dailyByBucket     Json     @map("daily_by_bucket")
  /// True when the cron's evaluateBudgetAlert tripped at least one
  /// threshold. Lets the admin page colour the row red without
  /// re-deriving the comparison.
  shouldAlert       Boolean  @default(false) @map("should_alert")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([snapshotDate(sort: Desc)])
  @@map("ai_cost_snapshots")
}

/// P2.D Audit log — immutable record of sensitive operations
/// (account delete, data export, admin dashboard view, cron failures
/// that affected user data, future payment events).
///
/// Append-only by convention — no `updateMany` or `delete` should be
/// called on this table outside of GDPR right-to-erasure flows. The
/// `actorId` is a free-form text (not a User FK) so the row survives
/// the actor's own delete; for system / cron / unauthenticated
/// actions, store a sentinel like `cron:visit-reminder-handler` or
/// `system:webhook.resend`.
///
/// `targetType` + `targetId` describe the SUBJECT of the action when
/// applicable (e.g. `targetType="user", targetId="<uuid>"` for a
/// delete). Both nullable — system events without a specific subject
/// (cron started, secret rotated) leave them empty.
model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Action verb namespaced by domain — see `src/server/audit.ts`'s
  /// `AuditAction` union for the canonical list. Stringly-typed so
  /// adding a new action doesn't require a migration.
  action      String
  /// Free-form actor identifier. Auth'd user → user UUID. Admin via
  /// allow-list → user UUID + `actorRole="admin"`. Cron / webhook /
  /// system → sentinel string (`cron:<name>`, `system:<name>`).
  actorId     String   @map("actor_id")
  /// Optional role label for the actor — `user` / `admin` / `system`
  /// / `cron`. Null when the action is system-only and the actorId
  /// already encodes the role.
  actorRole   String?  @map("actor_role")
  /// What was acted upon. Null for system-level events.
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  /// IP address (truncated to /24 for IPv4 / /48 for IPv6 by the
  /// caller, NOT here — the helper takes care of redaction). Null
  /// for actions that don't originate from an HTTP request.
  ipAddress   String?  @map("ip_address")
  /// User agent string (truncated to 256 chars by the caller).
  userAgent   String?  @map("user_agent")
  /// Free-form structured detail — e.g. `{ "email_hash": "...",
  /// "deleted_project_ids": [...] }`. Avoid raw PII; the helper
  /// hashes emails before storing.
  detail      Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([action, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

/// AI response cache — deduplicates identical Claude inputs across all call sites.
/// TTL = 30 days (enforced in application logic, not DB).
model AiCache {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inputHash String   @unique @map("input_hash")
  response  String
  model     String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ai_cache")
}

/// F1 venue-name-search: per-project, per-month counter of paid 3rd-party
/// API calls. Used as the soft cap for Google Places Autocomplete so we
/// can degrade gracefully (Tier 2 skip → Tier 3 only) instead of surprising
/// the user with a hard billing spike. One row per (projectId, yearMonth).
/// No FK on project_id to keep the counter resilient across project churn —
/// if a project is deleted the row just becomes orphaned scoring data.
model ApiUsageCounter {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId                String   @map("project_id") @db.Uuid
  /// YYYY-MM key. Cheaper than a date range for upsert + index.
  yearMonth                String   @map("year_month")
  placesAutocompleteCount  Int      @default(0) @map("places_autocomplete_count")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@unique([projectId, yearMonth])
  @@map("api_usage_counter")
}
