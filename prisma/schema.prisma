model CoachSession {
  id        String   @id @default(cuid())
  projectId String   @map("project_id") @db.Uuid
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages CoachMessage[]

  @@index([projectId, updatedAt(sort: Desc)])
  @@map("coach_sessions")
}

model CoachMessage {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String      @map("project_id") @db.Uuid
  sessionId String?     @map("session_id")
  role      MessageRole
  content   String
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session CoachSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([sessionId])
  // Every coach turn reads the session's last 20 messages
  // (`sendCoachMessage`) and probes the latest message for idempotent
  // user-message persistence (`persistUserMessageIdempotent`). Both
  // shapes are `where sessionId orderBy createdAt`, so the single-column
  // `sessionId` index forces a per-fetch sort once a session passes a
  // few dozen messages. Composite makes both index-ordered reads.
  @@index([sessionId, createdAt])
  @@map("coach_messages")
}

model NotificationPreference {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String                @unique @map("user_id") @db.Uuid
  frequency        NotificationFrequency @default(auto)
  pushEnabled      Boolean               @default(false) @map("push_enabled")
  emailEnabled     Boolean               @default(true) @map("email_enabled")
  pushSubscription Json?                 @map("push_subscription")
  /// P2.D Resend bounce / complaint suppression metadata.
  ///
  /// `emailSuppressedReason` records WHY the email leg was disabled so
  /// the daily retry cron (`/api/cron/email-suppression-retry`) can
  /// distinguish:
  ///
  ///   - `hard_bounce` — invalid address / permanent failure → never
  ///     auto-retry (user must update email via /mypage)
  ///   - `complained` — user marked as spam → never auto-retry
  ///     (deliverability + ESP relationship priority)
  ///   - `soft_bounce` — mailbox full / rate limit / DNS hiccup →
  ///     auto-retry after 7 days
  ///   - `manual` — user toggled it off in /mypage settings UI →
  ///     never auto-retry (the user is the SoT)
  ///   - null — emailEnabled was never auto-suppressed (default)
  ///
  /// `emailSuppressedAt` is set whenever a suppression is recorded so
  /// the retry cron can compare against `now - 7 days`.
  emailSuppressedReason String?   @map("email_suppressed_reason")
  emailSuppressedAt    DateTime? @map("email_suppressed_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Index supports the daily retry cron's
  // `where emailSuppressedReason='soft_bounce' AND emailSuppressedAt < cutoff`
  // scan without a full table sweep.
  @@index([emailSuppressedReason, emailSuppressedAt])
  @@map("notification_preferences")
}

