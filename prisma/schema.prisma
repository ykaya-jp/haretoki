generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectRole {
  owner
  partner
}

enum VenueStatus {
  researching
  visit_scheduled
  visited
  shortlisted
  selected
  rejected
}

enum ScoreDimension {
  atmosphere
  hospitality
  cuisine
  cost
  access
  reviews
  dress
  photo_video
  flowers
  staff_continuity
  capacity
  cancellation
  way_home_mood
  // v2 MECE dimensions (added 2026-04-17)
  ceremony_space
  banquet_space
  attire_items
  cost_contract
  logistics
  overall
}

enum ScoreSource {
  zexy
  wedding_park
  hanayume
  mynavi
  minna_no_wedding
  user_rating
  ai_analysis
  checklist_derived
}

enum EstimateSourceType {
  pdf_upload
  manual
  ai_extracted
}

enum EstimateItemCategory {
  attire
  cuisine
  photo_video
  flowers
  performance
  av_equipment
  venue_fee
  other
}

enum EstimateItemTier {
  minimum
  standard
  premium
  unknown
}

enum VisitStatus {
  scheduled
  completed
  cancelled
}

enum DressBringIn {
  allowed
  not_allowed
  negotiable
}

enum ChecklistItemStatus {
  unchecked
  yes
  no
}

enum AiAnalysisType {
  review_summary
  estimate_prediction
  comparison
  fit_reason
  matrix_insight
  visit_prep
  coach_chat
  rating_comparison
}

enum NotificationFrequency {
  auto
  quiet
  off
}

enum ReactionType {
  like
  maybe
  pass
}

enum ReviewSource {
  zexy
  wedding_park
  hanayume
  mynavi
  minna_no_wedding
}

enum MessageRole {
  user
  assistant
}

enum PaymentMethod {
  credit_card
  cash
  bank_transfer
  installment
}

enum AgreementStatus {
  discussing
  decided
  revisit
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectMembers         ProjectMember[]
  visitRatings           VisitRating[]
  visitNotes             VisitNote[]
  favorites              VenueFavorite[]
  notificationPreference NotificationPreference?
  notifications          Notification[]
  createdInvitations     ProjectInvitation[] @relation("ProjectInvitationCreator")
  consumedInvitations    ProjectInvitation[] @relation("ProjectInvitationConsumer")
  agreements             CoupleAgreement[]
  savedSearches          SavedSearch[]
  decisionTodosCompleted DecisionTodo[]     @relation("decision_todo_completer")

  @@map("users")
}

model Project {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  conditions  Json?
  currentStep Int      @default(1) @map("current_step")
  /// F3: cancelDecision 時に控えた直前の selectedVenueId。次の makeDecision
  /// で同一 venue なら todo 完了状態を保ち、別 venue なら reset するための
  /// 比較材料。cancel→make 以外では参照されない。
  lastCancelledVenueId String? @map("last_cancelled_venue_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members          ProjectMember[]
  venues           Venue[]
  estimates        Estimate[]
  analyses         AiAnalysis[]
  decisions        Decision[]
  partnerReactions PartnerReaction[]
  coachMessages    CoachMessage[]
  coachSessions    CoachSession[]
  checklists       ProjectChecklist[]
  rituals          DailyRitual[]
  invitations      ProjectInvitation[]
  agreements       CoupleAgreement[]
  savedSearches    SavedSearch[]
  decisionTodos    DecisionTodo[]

  @@map("projects")
}

/// E-1 Weather Ritual: 朝/夕に Claude が生成する 1 文。日次キャッシュ。
model DailyRitual {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  date       DateTime @db.Date
  weather    String   // "cloudy" | "break" | "clear" | "sunny"
  headline   String   // 明朝 1 文 (20-40 字)
  mood       String?  // 補足 (60 字)
  ctaLabel   String?  @map("cta_label")
  ctaHref    String?  @map("cta_href")
  seenAt     DateTime? @map("seen_at")
  actedAt    DateTime? @map("acted_at")
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date])
  @@index([projectId, date])
  @@map("daily_rituals")
}

model ProjectMember {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String       @map("project_id") @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  role       ProjectRole
  invitedAt  DateTime     @default(now()) @map("invited_at")
  acceptedAt DateTime?    @map("accepted_at")
  /// W12-1: per-member dimension weights (1-5 integer scale, 3=neutral default).
  /// Stored as Json keyed by Tier1Dimension (see src/lib/constants.ts). NULL =
  /// unset → computeWeighted() treats every dimension as weight 3 (equal),
  /// keeping current non-weighted callers behavior intact for existing rows.
  weights    Json?        @map("weights")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

/// E-11 1-tap 招待リンク: ProjectMember pre-create を避け、トークンを使った
/// one-time consume 型。リンクを受け取った partner が Google OAuth でログインし、
/// このトークンを consume すると自動で ProjectMember を作る。
model ProjectInvitation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  token       String    @unique
  createdBy   String    @map("created_by") @db.Uuid
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  consumedBy  String?   @map("consumed_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  // F4: guest view tracking — owner sees "相棒さんが見ました" without
  // the partner needing a full account. Written by the guest route
  // handler at most once per guest session (cookie screenCount gate).
  lastViewedAt DateTime? @map("last_viewed_at")
  viewCount    Int       @default(0) @map("view_count")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation("ProjectInvitationCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  consumer User?  @relation("ProjectInvitationConsumer", fields: [consumedBy], references: [id])

  @@index([projectId])
  @@index([expiresAt])
  @@map("project_invitations")
}

model Venue {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId      String      @map("project_id") @db.Uuid
  name           String
  location       String?
  accessInfo     String?     @map("access_info")
  capacityMin    Int?        @map("capacity_min")
  capacityMax    Int?        @map("capacity_max")
  ceremonyStyles String[]    @map("ceremony_styles")
  sourceUrls     String[]    @map("source_urls")
  photoUrls      String[]    @default([]) @map("photo_urls")
  status         VenueStatus @default(researching)
  costMin        Int?        @map("cost_min")
  costMax        Int?        @map("cost_max")
  dressBringIn   DressBringIn? @map("dress_bring_in")
  dressBringInFee Int?       @map("dress_bring_in_fee")
  /// @deprecated Free-text legacy column. Retained for data preservation — new
  /// reads/filters should use `paymentMethodEnums`. Left un-dropped so historical
  /// free-text values (e.g. "カード", "分割 12回") remain queryable during the
  /// transition window (R1.5c → R2).
  paymentMethods     String[]        @default([]) @map("payment_methods")
  paymentMethodEnums PaymentMethod[] @default([]) @map("payment_method_enums")
  /// Max allowed installment count. Null = unknown or not supported.
  maxInstallments    Int?            @map("max_installments")
  reviewEstimateDeltaYen    Int?     @map("review_estimate_delta_yen")
  reviewEstimateDeltaPct    Decimal? @map("review_estimate_delta_pct") @db.Decimal(5, 2)
  reviewEstimateSampleCount Int?     @map("review_estimate_sample_count")
  /// R-2 気分で探す: 式場の雰囲気タグ (VibeTag[])
  vibeTags           String[]        @default([]) @map("vibe_tags")
  /// AI-clustered review summary. Rolled up from the multi-page review
  /// corpus during URL import. Schema:
  ///   {
  ///     positive: [{ theme, summary, count? }],
  ///     negative: [{ theme, summary, count? }],
  ///     totalSampled: number,          // how many reviews the cluster pass saw
  ///     totalOnSource: number | null,   // site's headline count (e.g. zexy 1400)
  ///   }
  /// Null means clustering hasn't run (or isn't available for this venue).
  reviewClusters  Json?              @map("review_clusters")

  /// Deep extraction (v2) — JSON-LD derived
  externalRatingValue Float?    @map("external_rating_value")
  externalReviewCount Int?      @map("external_review_count")
  postalCode          String?   @map("postal_code") @db.VarChar(16)
  streetAddress       String?   @map("street_address")
  latitude            Float?
  longitude           Float?
  phoneNumber         String?   @map("phone_number") @db.VarChar(32)

  /// Facilities
  hasParking         Boolean? @map("has_parking")
  parkingCapacity    Int?     @map("parking_capacity")
  hasShuttle         Boolean? @map("has_shuttle")
  hasAccommodation   Boolean? @map("has_accommodation")
  acceptsSecondParty Boolean? @map("accepts_second_party")
  barrierFree        Boolean? @map("barrier_free")

  /// Cost breakdown (complements costMin/costMax)
  ceremonyFeeExact   Int?     @map("ceremony_fee_exact")
  productionFeeMin   Int?     @map("production_fee_min")
  productionFeeMax   Int?     @map("production_fee_max")
  serviceFeeRate     Decimal? @map("service_fee_rate") @db.Decimal(4, 3)

  /// Operating
  operatingHours     String?  @map("operating_hours") @db.VarChar(100)
  closedDays         String[] @default([]) @map("closed_days")

  /// Cuisine
  cuisineTypes       String[] @default([]) @map("cuisine_types")
  chefCredentials    String?  @map("chef_credentials") @db.VarChar(500)

  /// Dedupe key (lowercased, punctuation-stripped name)
  normalizedName     String?  @map("normalized_name") @db.VarChar(200)

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  /// W20-3: soft delete marker. `null` = live row, non-null timestamp = the
  /// couple has 手放した the venue but the row stays in place so we can
  /// surface 戻す later and audit the decision rather than vaporising the
  /// data on a stray tap. Every read path that surfaces venues to the
  /// user MUST `where: { deletedAt: null }`.
  deletedAt      DateTime?   @map("deleted_at")

  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scores           VenueScore[]
  estimates        Estimate[]
  visits           Visit[]
  analyses         AiAnalysis[]
  decision         Decision?
  favorites        VenueFavorite[]
  partnerReactions PartnerReaction[]
  reviews          Review[]
  plans            VenuePlan[]
  checklistAnswers VenueChecklistAnswer[]

  @@index([projectId])
  @@index([projectId, status])
  @@index([projectId, normalizedName])
  @@index([latitude, longitude])
  @@index([projectId, deletedAt])
  // home (`earliestVenue`) and journey (firstFavorite / firstVisit /
  // firstEstimate) probe the project's earliest / latest venue with
  // `orderBy: { createdAt: asc|desc }`. The single-column `projectId`
  // index forces Postgres to read every row and sort; the composite
  // returns the head tuple from an index-only scan.
  @@index([projectId, createdAt])
  @@map("venues")
}

model VenueScore {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId     String         @map("venue_id") @db.Uuid
  dimension   ScoreDimension
  score       Decimal        @db.Decimal(2, 1)
  source      ScoreSource
  reviewCount Int            @default(0) @map("review_count")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, dimension, source])
  @@index([venueId])
  @@map("venue_scores")
}

model Estimate {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId        String             @map("venue_id") @db.Uuid
  projectId      String             @map("project_id") @db.Uuid
  version        Int                @default(1)
  total          Int
  predictedFinal Int?               @map("predicted_final")
  sourceType     EstimateSourceType @map("source_type")
  pdfUrl         String?            @map("pdf_url")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  venue   Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   EstimateItem[]

  @@index([venueId])
  @@index([projectId])
  // Many hot paths (matrix, venues detail, comparison, coach context) select
  // the latest estimate for a venue via `orderBy: { version: desc }, take: 1`.
  // A composite (venueId, version desc) index lets Postgres resolve that in
  // an index-only scan instead of re-reading the single-column venueId index
  // and then sorting in memory.
  @@index([venueId, version(sort: Desc)])
  // R2 (Phase 2.D): four call sites do
  // `findFirst where projectId orderBy createdAt desc` to surface the
  // project's latest-by-time estimate (coach.ts loadUserContext,
  // ritual.ts buildRitualContext, coach/stream/route.ts, journey.ts).
  // The single-column projectId index forces a sort step on every read;
  // this composite serves the head row from an index-only scan.
  @@index([projectId, createdAt(sort: Desc)])
  @@map("estimates")
}

model EstimateItem {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estimateId         String               @map("estimate_id") @db.Uuid
  category           EstimateItemCategory
  itemName           String               @map("item_name")
  amount             Int
  tier               EstimateItemTier     @default(unknown)
  predictedUpgrade   Int?                 @map("predicted_upgrade")
  upgradeProbability Decimal?             @map("upgrade_probability") @db.Decimal(3, 2)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
  @@map("estimate_items")
}

model Visit {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId     String      @map("venue_id") @db.Uuid
  scheduledAt DateTime?   @map("scheduled_at")
  status      VisitStatus @default(scheduled)
  completedAt    DateTime?   @map("completed_at")
  title          String?
  memo           String?
  reminderSentAt DateTime?   @map("reminder_sent_at")
  /// F2 (W15 audit): iCalendar SEQUENCE counter. Incremented on every visit
  /// re-schedule so external calendars (Google / Apple / Outlook) reliably
  /// overwrite existing events via the same UID. RFC 5545 §3.8.7.4 requires
  /// a non-negative integer; we start at 0 and use `{ increment: 1 }`.
  sequence           Int        @default(0)
  /// F2 (W15 audit): timestamp when the user successfully downloaded the
  /// .ics for this visit. Null = never exported. Set by the
  /// `markVisitCalendarExported` server action *after* the client-side
  /// download completes (not inside the route handler, to avoid prefetch /
  /// link-preview false positives). Also used to exclude externally-managed
  /// visits from the push-reminder cron.
  calendarExportedAt DateTime?  @map("calendar_exported_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  /// W20-3: soft delete. Cascaded inside `deleteVenue`'s transaction so the
  /// PDP / past-visits view stops surfacing the row alongside the parent
  /// venue. Reserved for future per-visit "見学だけ取り消す" UI.
  deletedAt   DateTime?   @map("deleted_at")

  venue     Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  checklist VisitChecklistItem[]
  notes     VisitNote[]
  ratings   VisitRating[]

  @@index([venueId])
  @@index([venueId, deletedAt])
  // R2 (Phase 2.D): the visit-reminders crons
  // (`/api/cron/visit-reminders-day-before` + `-morning-of`) scan for
  // upcoming visits with `where status='scheduled' AND scheduledAt range`
  // — no venueId filter. Without a (status, scheduledAt) composite the
  // planner falls back to a sequential table scan; this composite lets
  // the daily cron resolve in milliseconds even with thousands of past
  // visits accumulated. Equality on status first (highly selective —
  // most rows are `completed` or `cancelled`), range on scheduledAt
  // second.
  @@index([status, scheduledAt])
  // R2 (Phase 2.D): home.ts upcoming-visit count and journey.ts
  // completed-visit count both run `count where venue.projectId AND
  // status='X'`. The relational filter joins via venues' projectId
  // index, then for each venue scans visits — without a (venueId,
  // status) composite the inner status filter is a per-row check.
  // This index lets the inner side complete index-only.
  @@index([venueId, status])
  @@map("visits")
}

model VisitChecklistItem {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  visitId   String              @map("visit_id") @db.Uuid
  item      String
  category  String?
  status    ChecklistItemStatus @default(unchecked)
  memo      String?
  photoUrls String[]            @default([]) @map("photo_urls")
  checkedAt DateTime?           @map("checked_at")
  sortOrder Int                 @default(0) @map("sort_order")
  metadata  Json?
  /// W20-3: soft delete. Cascades via `deleteVenue`'s transaction; per-item
  /// "手放す" UI is not in scope today but the column unlocks it later.
  deletedAt DateTime?           @map("deleted_at")

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  // `visit-questions.ts` and `checklist-comparison.ts` read the checklist
  // ordered by `sortOrder asc`. A (visitId, sortOrder) composite index
  // avoids the per-query sort for visits with many items.
  @@index([visitId, sortOrder])
  @@map("visit_checklist_items")
}

model VisitNote {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  visitId     String   @map("visit_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  content     String
  tags        String[]
  locationLat Decimal? @map("location_lat") @db.Decimal(9, 6)
  locationLng Decimal? @map("location_lng") @db.Decimal(9, 6)
  createdAt   DateTime @default(now()) @map("created_at")
  /// W20-3: soft delete. Cascades via `deleteVenue`'s transaction; the same
  /// column also lets the couple 手放す a single memo without losing the
  /// rest of the visit's notes.
  deletedAt   DateTime? @map("deleted_at")

  visit Visit           @relation(fields: [visitId], references: [id], onDelete: Cascade)
  user  User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  media VisitNoteMedia[]

  @@index([visitId])
  @@index([userId])
  @@index([visitId, deletedAt])
  @@map("visit_notes")
}

model VisitNoteMedia {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  visitNoteId String   @map("visit_note_id") @db.Uuid
  type        String
  mediaUrl    String   @map("media_url")
  createdAt   DateTime @default(now()) @map("created_at")

  visitNote VisitNote @relation(fields: [visitNoteId], references: [id], onDelete: Cascade)

  @@index([visitNoteId])
  @@map("visit_note_media")
}

model VisitRating {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  visitId   String         @map("visit_id") @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  dimension ScoreDimension
  score     Decimal        @db.Decimal(2, 1)
  comment   String?
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  /// W20-3: soft delete. Cascades via `deleteVenue`; per-rating "手放す" is
  /// not in scope today but the column unlocks it later without another
  /// migration.
  deletedAt DateTime?      @map("deleted_at")

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([visitId, userId, dimension])
  @@index([userId])
  @@index([visitId, deletedAt])
  @@map("visit_ratings")
}

model AiAnalysis {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId   String?        @map("venue_id") @db.Uuid
  projectId String         @map("project_id") @db.Uuid
  type      AiAnalysisType
  inputHash String?        @map("input_hash")
  output    String
  createdAt DateTime       @default(now()) @map("created_at")

  venue   Venue?  @relation(fields: [venueId], references: [id], onDelete: SetNull)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, type])
  @@index([projectId, type, inputHash])
  // `getAIInsights` throttle gate (`insights.ts`) reads the project's most
  // recent analysis with `orderBy: { createdAt: desc }, take: 1`. Without a
  // (projectId, createdAt) composite Postgres scans all (projectId, type)
  // rows and sorts; this index lets the throttle check resolve in one tuple.
  @@index([projectId, createdAt(sort: Desc)])
  @@map("ai_analyses")
}

model Decision {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String   @unique @map("project_id") @db.Uuid
  selectedVenueId String   @unique @map("selected_venue_id") @db.Uuid
  rationale       String?
  decidedAt       DateTime @default(now()) @map("decided_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  venue   Venue   @relation(fields: [selectedVenueId], references: [id])

  @@map("decisions")
}

/// F3: 決定後に発生する実務タスク。makeDecision の post-commit で 15 件 seed。
/// ProjectChecklist とは用途が独立（観察 vs 行動）のため別モデル。
model DecisionTodo {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String       @map("project_id") @db.Uuid
  templateKey   String       @map("template_key")
  source        TodoSource   @default(system)
  title         String
  description   String?
  priority      TodoPriority @default(normal)
  dueOffsetDays Int?         @map("due_offset_days")
  orderIndex    Int          @map("order_index")
  completedAt   DateTime?    @map("completed_at")
  completedBy   String?      @map("completed_by") @db.Uuid
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  completer User?   @relation("decision_todo_completer", fields: [completedBy], references: [id], onDelete: SetNull)

  @@unique([projectId, templateKey])
  @@index([projectId, completedAt])
  @@index([projectId, orderIndex])
  // `getTopTodos` (home hero "次の一歩") filters `where: { projectId,
  // completedAt: null }` then `orderBy: { orderIndex: asc } take: 3`.
  // The pair indexes above each cover one half; combining them lets
  // Postgres serve the home page query as an index-only scan instead of
  // filtering one index then sorting in memory.
  @@index([projectId, completedAt, orderIndex])
  @@map("decision_todos")
}

enum TodoSource {
  system
  custom
}

enum TodoPriority {
  high
  normal
  low
}

model PartnerReaction {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId      String       @map("venue_id") @db.Uuid
