{
  "name": "dev",

  // ★worktree 対策：ホストの ~/projects をコンテナ内でも同じパスへ bind
  // これで worktree の .git 参照先（本体 .git/worktrees/...）がコンテナ内でも解決できる
  "workspaceMount": "source=${localEnv:HOME}/projects,target=${localEnv:HOME}/projects,type=bind,consistency=cached",
  "workspaceFolder": "${localWorkspaceFolder}",

  "build": {
    "dockerfile": "Dockerfile"

    // ★任意：後述の GHCR prebuild を使うなら cacheFrom を入れる
    "cacheFrom": ["ghcr.io/<OWNER>/<REPO>-devcontainer:latest"]
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "username": "vscode"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // UID/GID をホストに合わせ bind mount の権限事故を減らす（デフォルト true）
  "updateRemoteUserUID": true
}
